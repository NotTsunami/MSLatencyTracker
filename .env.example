# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mslatencytracker

# Server
PORT=8080

# Ping configuration (optional — defaults shown)
# PING_INTERVAL_MS=300000
# PING_TIMEOUT_S=5

# History retention in hours (optional — default 24)
# HISTORY_RETENTION_HOURS=24

# Cleanup interval in minutes (optional — default 60)
# CLEANUP_INTERVAL_MIN=60
