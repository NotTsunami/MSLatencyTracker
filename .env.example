# --- Docker Compose ---
# Credentials for the bundled postgres container. The tracker's DATABASE_URL
# is derived from these automatically; only the password is required.
POSTGRES_PASSWORD=change-me
# POSTGRES_USER=mslatency
# POSTGRES_DB=mslatency

# Cloudflare Tunnel token for the bundled cloudflared container. Create a
# remotely-managed tunnel (Zero Trust → Networks → Tunnels → Create a tunnel
# → Cloudflared) and paste the token from the install command here.
TUNNEL_TOKEN=change-me

# --- Local development (go run .) ---
# Required when running outside Docker Compose, which supplies its own.
DATABASE_URL=postgresql://user:password@localhost:5432/mslatencytracker

# Server
PORT=8080

# Ping configuration (optional — defaults shown)
# PING_INTERVAL_MS=300000
# PING_TIMEOUT_S=5

# History retention in hours (optional — default 24)
# HISTORY_RETENTION_HOURS=24

# Cleanup interval in minutes (optional — default 60)
# CLEANUP_INTERVAL_MIN=60
